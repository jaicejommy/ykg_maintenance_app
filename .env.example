# Environment variable configuration for Yokogawa Maintenance System
# ─────────────────────────────────────────────────────────────────────────────
# INSTRUCTIONS:
#   1. Copy this file to .env:   cp .env.example .env
#   2. Replace every placeholder value with a real value before running.
#   3. Never commit the .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── JWT / Authentication ─────────────────────────────────────────────────────
# SECRET_KEY: Long random string used to sign JWTs.
#   Generate with: python -c "import secrets; print(secrets.token_hex(32))"
#   Minimum 32 characters. Treat as a password — keep private.
SECRET_KEY=replace_with_a_long_random_string_minimum_32_characters

# ALGORITHM: JWT signing algorithm. HS256 is the recommended default.
ALGORITHM=HS256

# ACCESS_TOKEN_EXPIRE_MINUTES: Session duration in minutes before JWT expires.
#   480 = 8 hours (a typical shift length). Reduce for higher security.
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Default Administrator Account ────────────────────────────────────────────
# These credentials are used to seed the first admin account on startup
# ONLY if the users table is empty. Change the password immediately after
# first login.
DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_PASSWORD=change_me_on_first_login

# ── File Upload Limits ────────────────────────────────────────────────────────
# MAX_UPLOAD_SIZE_MB: Maximum allowed attachment size in megabytes.
#   Enforced server-side — client-side warning is a courtesy check only.
MAX_UPLOAD_SIZE_MB=10

# ── CORS ─────────────────────────────────────────────────────────────────────
# ALLOWED_ORIGINS: Comma-separated list of allowed origins for cross-origin
#   requests. For a plant intranet where the frontend and backend share the
#   same origin, leave this blank or set to the exact host URL.
#   Example: http://192.168.1.100:8000,http://localhost:8000
#   Leave blank to allow all origins (not recommended for production).
ALLOWED_ORIGINS=
